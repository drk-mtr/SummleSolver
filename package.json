{
  "name": "summlesolver",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "npm run build:wasm && vite",
    "build": "npm run build:wasm && vue-tsc -b && vite build",
    "build:wasm": "wasm-pack build solver-wasm --target web --release 2>/dev/null || ~/.cargo/bin/wasm-pack build solver-wasm --target web --release",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "bench": "vitest bench"
  },
  "dependencies": {
    "@tailwindcss/vite": "^4.2.2",
    "tailwindcss": "^4.2.2",
    "vue": "^3.5.30"
  },
  "devDependencies": {
    "@types/node": "^24.12.0",
    "@vitejs/plugin-vue": "^6.0.5",
    "@vue/test-utils": "^2.4.6",
    "@vue/tsconfig": "^0.9.0",
    "jsdom": "^29.0.1",
    "typescript": "~5.9.3",
    "vite": "^8.0.1",
    "vite-plugin-wasm": "^3.6.0",
    "vitest": "^4.1.2",
    "vue-tsc": "^3.2.5"
  }
}
